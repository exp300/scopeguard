# ScopeGuard Backend — Environment Variables
# Copy this to .env and fill in your values

# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
# Local dev example: postgres://user:password@localhost:5432/scopeguard
DATABASE_URL=postgres://...

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Paddle keys (https://vendors.paddle.com/authentication)
PADDLE_API_KEY=pdl_snd_...        # Paddle API key (use sandbox key for dev, live key for production)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_... # from: Paddle dashboard → Notifications → webhook secret
PADDLE_PRO_PRICE_ID=pri_...       # create a $19/month recurring price in Paddle dashboard

# JWT secret — any long random string
JWT_SECRET=change-me-to-a-long-random-string-minimum-32-chars

# AES-256 encryption key for contract text at rest — any string, keep secret
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-random-secret-string

# Server port (Railway sets this automatically — do not override in production)
PORT=3001

# Resend API key for transactional email (https://resend.com/api-keys)
RESEND_API_KEY=re_...
# From address — use onboarding@resend.dev until you verify a custom domain
EMAIL_FROM=onboarding@resend.dev

# Node environment — set to "production" on Railway
NODE_ENV=development

# Frontend URL — used for Stripe redirect URLs and dev CORS
# In production set this to your Railway app URL e.g. https://scopeguard.up.railway.app
FRONTEND_URL=http://localhost:5173
