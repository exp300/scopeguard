# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment — never commit secrets
.env
backend/.env
frontend/.env

# SQLite database — use Railway Volume for persistence in production
backend/db/*.db
backend/db/*.db-shm
backend/db/*.db-wal

# Uploaded files (PDFs are deleted after parsing, but just in case)
backend/uploads/*
!backend/uploads/.gitkeep

# Frontend build output
frontend/dist/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
